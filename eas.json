{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "BABY_LOG_API_URL": "http://localhost:8092"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "BABY_LOG_API_URL": "https://api.babylog.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "BABY_LOG_API_URL": "https://api.babylog.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "giwon1130@gmail.com",
        "ascAppId": "",
        "appleTeamId": ""
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
